<!DOCTYPE html>
<html>
<head>
    <title>Tribute Page</title>

    <!-- Internal CSS -->
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
        }

        /* Navigation Bar */
        nav {
            background-color: #333;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 15px;
            text-decoration: none;
            font-size: 18px;
        }

        nav a:hover {
            color: yellow;
        }

        /* Main Container */
        .container {
            text-align: center;
            padding: 20px;
        }

        /* Image Styling */
        img {
            width: 200px;
            border-radius: 50%;
            border: 5px solid #333;
        }

        /* Text Styling */
        h1 {
            color: #333;
        }

        p {
            font-size: 18px;
            color: #555;
        }

        /* Card Section */
        .card {
            background-color: white;
            padding: 20px;
            margin: 20px auto;
            width: 70%;
            border-radius: 10px;
            box-shadow: 0 0 10px gray;
        }
    </style>
</head>

<body>

    <!-- Navigation Bar -->
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Achievements</a>
        <a href="#">Contact</a>
    </nav>

    <!-- Profile Section -->
    <div class="container">
        <h1>Tribute to Dr. A.P.J. Abdul Kalam</h1>
        <img src="https://upload.wikimedia.org/wikipedia/commons/9/99/A._P._J._Abdul_Kalam.jpg" alt="APJ Abdul Kalam">
    </div>

    <!-- About Section -->
    <div class="card">
        <h2>About</h2>
        <p>
            Dr. A.P.J. Abdul Kalam was the 11th President of India and a great scientist.
            He is known as the "Missile Man of India" for his contribution to India's defense and space research.
        </p>
    </div>

    <!-- Achievements Section -->
    <div class="card">
        <h2>Achievements</h2>
        <p>
            • Developed India's first satellite launch vehicle<br>
            • Played a key role in nuclear tests<br>
            • Awarded Bharat Ratna<br>
            • Inspired millions through his books and speeches
        </p>
    </div>

    <!-- Footer -->
    <div class="container">
        <p>Created using Internal CSS | Web Designing Lab</p>
    </div>

</body>
</html>
