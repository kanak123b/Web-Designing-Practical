<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Professional Demo</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container">
    <a class="navbar-brand fw-bold" href="#">MySite</a>
    
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="menu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="#">About</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Services</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Carousel -->
<div id="slider" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">

    <div class="carousel-item active">
      <img src="https://via.placeholder.com/1200x400" class="d-block w-100">
      <div class="carousel-caption">
        <h3>Welcome to My Website</h3>
        <p>Modern Bootstrap Design</p>
      </div>
    </div>

    <div class="carousel-item">
      <img src="https://via.placeholder.com/1200x400" class="d-block w-100">
      <div class="carousel-caption">
        <h3>Responsive Layout</h3>
        <p>Works on all devices</p>
      </div>
    </div>

  </div>

  <!-- Controls -->
  <button class="carousel-control-prev" data-bs-target="#slider" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" data-bs-target="#slider" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>

<!-- Cards Section -->
<div class="container mt-5">
  <h2 class="text-center mb-4">Our Services</h2>

  <div class="row g-4">

    <div class="col-md-4">
      <div class="card shadow">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5 class="card-title">Web Design</h5>
          <p class="card-text">Create beautiful and responsive websites.</p>
          <button class="btn btn-primary">Learn More</button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5 class="card-title">Development</h5>
          <p class="card-text">Build powerful web applications.</p>
          <button class="btn btn-success">Learn More</button>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body text-center">
          <h5 class="card-title">Support</h5>
          <p class="card-text">24/7 support for your projects.</p>
          <button class="btn btn-danger">Learn More</button>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Footer -->
<footer class="bg-dark text-white text-center mt-5 p-4">
  <p class="mb-0">© 2026 MySite | Designed with Bootstrap</p>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
